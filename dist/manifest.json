{
	"manifest_version": 3,
	"name": "FxPlus+ for Chrome",
	"short_name": "FxPlus+",
	"author": "SilverTuxedo",
	"description": "מעולם לא היה קל יותר לגלוש ב-FxP.",
	"version": "1.5.5",
	"icons": {
		"16": "./logo/logo-16.png",
		"48": "./logo/logo-48.png",
		"128": "./logo/logo-128.png"
	},
	"permissions": [
		"activeTab",
		"storage",
		"notifications",
		"cookies",
		"alarms"
	],

	"background": {
	},

	"content_scripts": [{
		"matches": ["https://www.fxp.co.il/*"],
		"js": ["./main.bundle.js"],
		"css": ["./main_fxp.css"]
	}]
}

